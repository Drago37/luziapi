{% set home = function('home_url', '/') %}
{% set shop = function('wc_get_page_permalink', 'shop') %}
<div class="fab" aria-label="Accès rapide">
    <a href="{{ home }}#newsletter" aria-label="S'abonner à la newsletter">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22zm6-6V11c0-3.07-1.64-5.64-4.5-6.32V4a1.5 1.5 0 0 0-3 0v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg>
        <span class="label">S'abonner</span>
    </a>
    {% if contact.facebook %}
    <a href="{{ contact.facebook }}" target="_blank" rel="noopener" aria-label="Page Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7h2.3l.35-2.7H13.5V9.6c0-.78.22-1.3 1.33-1.3h1.42V5.9c-.25-.03-1.1-.1-2.08-.1-2.06 0-3.47 1.26-3.47 3.57v1.98H8.4V14h2.3v7h2.8z"/></svg>
        <span class="label">Facebook</span>
    </a>
    {% endif %}
    <a class="is-shop" href="{{ shop ?: (home ~ '#produits') }}" aria-label="Aller à la boutique">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM7.2 14.6l.03-.12.9-1.64h6.45c.75 0 1.4-.41 1.74-1.03l3.58-6.49-1.74-.96-3.58 6.49H8.53L4.27 2H1v2h2l3.6 7.59-1.35 2.44C4.52 15.37 5.48 17 7 17h12v-2H7.42c-.13 0-.23-.11-.22-.4z"/></svg>
        <span class="label">Boutique</span>
    </a>
    <a href="{{ home }}#contact" aria-label="Aller au formulaire de contact">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm9 7L4 7v1l8 5 8-5V7l-8 5z"/></svg>
        <span class="label">Contact</span>
    </a>
</div>
