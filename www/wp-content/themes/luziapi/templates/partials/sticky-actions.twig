{% set home = function('home_url', '/') %}
{% set shop = function('wc_get_page_permalink', 'shop') %}
<div class="fab" aria-label="Accès rapide">
    {% if contact.facebook %}
    <a href="{{ contact.facebook }}" target="_blank" rel="noopener" aria-label="Page Facebook">
        <span class="label">Facebook</span>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7h2.3l.35-2.7H13.5V9.6c0-.78.22-1.3 1.33-1.3h1.42V5.9c-.25-.03-1.1-.1-2.08-.1-2.06 0-3.47 1.26-3.47 3.57v1.98H8.4V14h2.3v7h2.8z"/></svg>
    </a>
    {% endif %}
    <a href="{{ shop ?: (home ~ '#produits') }}" aria-label="Aller à la boutique">
        <span class="label">Boutique</span>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 8V7a5 5 0 0 1 10 0v1h2.2l.8 12H4l.8-12H7zm2 0h6V7a3 3 0 0 0-6 0v1z"/></svg>
    </a>
    <a href="{{ home }}#contact" aria-label="Aller au formulaire de contact">
        <span class="label">Contact</span>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm9 7L4 7v1l8 5 8-5V7l-8 5z"/></svg>
    </a>
</div>
