            <span class="wm">Luzi<b>Api</b></span>
        </a>

        <button class="burger" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>

        <nav class="menu">
            <a href="{{ home }}#apiculteur">L'apiculteur</a>
            <a href="{{ home }}#savoir-faire">Savoir-faire</a>
            <a href="{{ home }}#produits">Nos miels</a>
            <a href="{{ home }}#localisation">Nous trouver</a>
            <a href="{{ home }}#contact">Contact</a>
            <a class="btn btn-primary" href="{{ shop ?: (home ~ '#produits') }}">Boutique</a>
