# Variables d'environnement — VERSIONNÉ (valeurs par défaut, AUCUN secret).
# Pour surcharger en local (secrets, accès serveur) : créer un .env.local (non versionné).
# Ordre de chargement (Makefile) : .env puis .env.local — .env.local a la priorité.

# Base de données (locale Docker)
DB_NAME=luziapi
DB_USER=luziapi
DB_PASSWORD=luziapi
DB_ROOT_PASSWORD=root

# Ports exposés en local
WP_PORT=8080
PMA_PORT=8081

# ---------------------------------------------------------------------------
# Déploiement o2switch (`make deploy`)
# ⚠ Les accès/secrets se mettent dans .env.local, PAS ici.
# ---------------------------------------------------------------------------
# DEPLOY_HOST : hôte SSH o2switch (ex: nodeXXXX.n0c.com)
# DEPLOY_USER : login cPanel
# DEPLOY_PATH : dossier du thème sur le serveur (ex: ~/public_html/wp-content/themes/luziapi)
# DEPLOY_KEY  : chemin LOCAL de la clé SSH privée (ex: ~/.ssh/id_ed25519_o2switch)
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PORT=22
DEPLOY_PATH=
DEPLOY_KEY=
