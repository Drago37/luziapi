# Variables d'environnement — VERSIONNÉ (valeurs par défaut, AUCUN secret).
# Pour surcharger en local (secrets, accès serveur) : créer un .env.local (non versionné).
# Ordre de chargement (Makefile) : .env puis .env.local — .env.local a la priorité.

# Base de données (locale Docker)
DB_NAME=luziapi
DB_USER=luziapi
DB_PASSWORD=luziapi
DB_ROOT_PASSWORD=root

# Ports exposés en local
WP_PORT=8080
PMA_PORT=8081

# ---------------------------------------------------------------------------
# Déploiement o2switch en FTPS (`make deploy`)
# ⚠ Les accès/secrets (USER, PASS) se mettent dans .env.local, PAS ici.
# ---------------------------------------------------------------------------
# DEPLOY_FTP_HOST   : nom du serveur o2switch (ex: xxx.o2switch.net) — et NON le domaine,
#                     pour que le certificat TLS corresponde (verify-certificate=yes)
# DEPLOY_FTP_USER   : compte FTP (cPanel ou compte FTP dédié)
# DEPLOY_FTP_PASS   : mot de passe FTP (→ .env.local uniquement)
# DEPLOY_FTP_PATH   : dossier du thème sur le serveur (ex: public_html/wp-content/themes/luziapi)
# DEPLOY_FTP_PORT   : port FTP (o2switch = 21)
# DEPLOY_FTP_VERIFY : vérifier le certificat TLS (yes ; mettre no si mismatch de hostname)
DEPLOY_FTP_HOST=
DEPLOY_FTP_USER=
DEPLOY_FTP_PATH=
DEPLOY_FTP_PORT=21
DEPLOY_FTP_VERIFY=yes
