# Copier en .env puis ajuster si besoin.
#
# Chargement (priorité croissante) :
#   .env          → valeurs par défaut (ce fichier, recopié)
#   .env.local    → overrides & SECRETS, NON versionné (clé SSH, accès serveur…)
#
# Base de données (locale Docker)
DB_NAME=luziapi
DB_USER=luziapi
DB_PASSWORD=luziapi
DB_ROOT_PASSWORD=root

# Ports exposés en local
WP_PORT=8080
PMA_PORT=8081

# ---------------------------------------------------------------------------
# Déploiement o2switch (`make deploy`) — mettre les vraies valeurs dans .env.local
# ---------------------------------------------------------------------------
# DEPLOY_HOST : hôte SSH du serveur o2switch (ex: nodeXXXX.n0c.com)
# DEPLOY_USER : ton login cPanel
# DEPLOY_PORT : port SSH (o2switch = 22)
# DEPLOY_PATH : chemin du dossier du thème sur le serveur
#               (ex: ~/public_html/wp-content/themes/luziapi)
# DEPLOY_KEY  : chemin LOCAL de ta clé SSH privée (ex: ~/.ssh/id_ed25519_o2switch)
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PORT=22
DEPLOY_PATH=
DEPLOY_KEY=
